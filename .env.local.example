# Copy to .env.local and fill in. Never commit .env.local.

# --- Anthropic (powers the chat / calorie estimates) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Supabase (database) ---
# Project Settings → API. Use the SERVICE ROLE key (server-only, kept secret).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...

# --- USDA FoodData Central (optional but recommended for food lookup) ---
# Free key from https://api.data.gov/signup/ — used server-side only.
USDA_API_KEY=

# --- App access ---
# The shared password you'll type to unlock the app.
APP_PASSWORD=choose-a-good-passphrase
# A long random string used to sign the session cookie.
# Generate one with:  openssl rand -hex 32
AUTH_SECRET=replace-with-random-hex
